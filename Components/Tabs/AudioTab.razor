    private async Task PerformSearch()
    {
        await ApplyFiltersAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        var results = _audioRecords.AsEnumerable();

        // 1. Source Filter
        if (_selectedSource == "manual") results = results.Where(r => r.Source != "youtube");
        else if (_selectedSource == "youtube") results = results.Where(r => r.Source == "youtube");

        // 2. Playlist Filter
        if (!string.IsNullOrEmpty(_selectedPlaylistId))
        {
            if (_selectedPlaylistId == "any-playlist")
            {
                results = results.Where(r => _guidsInAnyPlaylist.Contains(r.GUID));
            }
            else if (_selectedPlaylistId == "none-playlist")
            {
                results = results.Where(r => !_guidsInAnyPlaylist.Contains(r.GUID));
            }
            else
            {
                var guidsInPlaylist = _playlistItems.Select(p => p.GUID).ToHashSet();
                results = results.Where(r => guidsInPlaylist.Contains(r.GUID));
            }
        }

        // 3. Search Query
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var segments = _searchQuery.Split(',', StringSplitOptions.RemoveEmptyEntries);
            foreach (var segment in segments)
            {
                var parts = segment.Split(':', 2);
                if (parts.Length < 2) continue;

                var tag = parts[0].Trim().ToLower();
                var value = parts[1].Trim().ToLower().Replace("_", " ");

                results = tag switch
                {
                    "source" => results.Where(r => r.Source?.ToLower().Contains(value) == true),
                    "artist" => results.Where(r => r.Artist?.ToLower().Contains(value) == true),
                    "album" => results.Where(r => r.Album?.ToLower().Contains(value) == true),
                    "genre" => results.Where(r => r.Genre?.ToLower().Contains(value) == true),
                    "year" => results.Where(r => r.Year?.ToString().Contains(value) == true),
                    "title" => results.Where(r => (r.AlternativeTitle?.ToLower().Contains(value) == true) || (r.Title?.ToLower().Contains(value) == true)),
                    _ => results
                };
            }
        }

        // 4. Status Filter
        if (_selectedStatus != "all")
        {
            if (_selectedStatus == "standard") results = results.Where(r => r.EnrichmentStatus == 0);
            else if (_selectedStatus == "partial") results = results.Where(r => r.EnrichmentStatus == 2);
            else if (_selectedStatus == "full") results = results.Where(r => r.EnrichmentStatus == 1);
            else if (_selectedStatus == "disabled") results = results.Where(r => r.EnrichmentStatus == 3 || r.EnrichmentStatus >= 10);
            else if (_selectedStatus == "manual") results = results.Where(r => r.EnrichmentStatus == 4);
        }

        // 5. Sorting
        results = _selectedSort switch
        {
            "title" => _isSortAscending 
                ? results.OrderBy(r => GetSortGroup(GetSortTitle(r))).ThenBy(r => GetSortTitle(r))
                : results.OrderBy(r => GetSortGroup(GetSortTitle(r))).ThenByDescending(r => GetSortTitle(r)),
            "artist" => _isSortAscending 
                ? results.OrderBy(r => GetSortGroup(r.Artist)).ThenBy(r => r.Artist)
                : results.OrderBy(r => GetSortGroup(r.Artist)).ThenByDescending(r => r.Artist),
            "year" => _isSortAscending ? results.OrderBy(r => r.Year) : results.OrderByDescending(r => r.Year),
            "added" => _isSortAscending ? results.OrderBy(r => r.CreatedAt) : results.OrderByDescending(r => r.CreatedAt),
            _ => results
        };

        _filteredRecords = results.ToList();
        StateHasChanged();
    }

