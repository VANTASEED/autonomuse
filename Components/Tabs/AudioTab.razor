@using Autonomuse.Domain.Entities
@using Autonomuse.Shared.Contracts
@using Autonomuse.Shared.Utilities
@inject IAudioService AudioService
@inject ISettingsService SettingsService
@inject IAudioEnrichmentService EnrichmentService
@inject AudioWatchService WatchService
@inject IJSRuntime JSRuntime

<div class="tab-content">
    <div class="header">
        @if (_showPlaylistManager)
        {
            <h1>Audio Library / Playlist Manager</h1>
            <p>Add or remove tracks from your playlists</p>
        }
        else if (_showWatchManager)
        {
            <h1>Audio Library / Watcher</h1>
            <p>Monitor YouTube playlists for new audio</p>
        }
        else
        {
            <h1>Audio Library</h1>
            <p>Manage and listen to your local audio collection</p>
        }
    </div>

    <div class="audio-content">
        @if (!_showPlaylistManager && !_showWatchManager)
        {
        <div class="control-cards glass-card">
            <div class="control-actions">
                @if (_isEnrichingAll)
                {
                    <div class="global-progress">
                        <span class="progress-label">@_globalProgressMessage</span>
                        <div class="progress-bar mini">
                            <div class="progress-fill" style="width: @(_globalProgress * 100)%"></div>
                        </div>
                    </div>
                }
                else
                {
                    @if (!_isSelectionMode)
                    {
                        <button class="action-btn select-audio" @onclick="ToggleSelectionMode" disabled="@_isEnrichingAll">
                            Select
                        </button>
                        <button class="action-btn" @onclick="TogglePlaylistManager">
                            Manage
                        </button>
                        <div class="split-pill mini">
                            <button class="split-btn" @onclick="ToggleWatchManager">Watcher</button>
                            <div class="divider"></div>
                            <button class="split-btn" @onclick="SyncWatchedPlaylistsAsync" title="Sync all watched playlists">
                                <span class="@(WatchService.IsSyncing ? "spin-icon" : "")">↻</span>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="split-pill mini">
                            <button class="split-btn" @onclick="ToggleSelectionMode">Cancel</button>
                            <div class="divider"></div>
                            <button class="split-btn" @onclick="SelectAll">Select All</button>
                        </div>
                        @if (_showDeleteConfirm)
                        {
                            <div class="confirm-group">
                                <span class="confirm-text">Delete @_selectedGuids.Count items?</span>
                                <button class="action-btn danger-btn" @onclick="ConfirmDeleteSelectedAsync">Confirm</button>
                                <button class="action-btn select-audio" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                            </div>
                        }
                        else
                        {
                            <button class="action-btn enrich-selected" @onclick="EnrichSelectedAsync" disabled="@(_selectedGuids.Count == 0)">
                                <i class="icon-sparkles"></i> Enrich (@_selectedGuids.Count)
                            </button>
                            <button class="action-btn" @onclick="LockSelectedAsync" disabled="@(_selectedGuids.Count == 0)">
                                <i class="icon-disable"></i> Lock (@_selectedGuids.Count)
                            </button>
                            <button class="action-btn" @onclick="UnlockSelectedAsync" disabled="@(_selectedGuids.Count == 0)">
                                <i class="icon-enable"></i> Unlock (@_selectedGuids.Count)
                            </button>
                            <button class="action-btn danger-btn" @onclick="() => _showDeleteConfirm = true" disabled="@(_selectedGuids.Count == 0)">
                                Delete Selected (@_selectedGuids.Count)
                            </button>
                        }
                    }

                    <div class="search-container">
                        <div class="search-input-wrapper">
                            <i class="icon-search-mini"></i>
                            <input type="text" 
                                   @bind="_searchQuery" 
                                   @bind:event="oninput" 
                                   @onkeyup="HandleSearchKeyUp"
                                   placeholder="artist:daft_punk, genre:electronic..." 
                                   class="search-input" />
                            @if (!string.IsNullOrEmpty(_searchQuery))
                            {
                                <button class="clear-search" @onclick="ClearSearch">×</button>
                            }
                            <div class="search-tooltip">
                                <div class="tooltip-header">Search Tags</div>
                                <div class="tooltip-body">
                                    <p>Filter your library using tags separated by commas, <br/>and use underscores for multi-word tags:</p>
                                    <ul>
                                        <li><strong>source</strong> filter by source (e.g. <code>youtube</code>, <code>manual</code>)</li>
                                        <li><strong>artist</strong> filter by artist (e.g. <code>daft_punk</code>)</li>
                                        <li><strong>album</strong> filter by album name</li>
                                        <li><strong>genre</strong> filter by genre (e.g. <code>electronic</code>)</li>
                                        <li><strong>year</strong> filter by year (e.g. <code>2013</code>)</li>
                                        <li><strong>title</strong> filter by song title</li>
                                    </ul>
                                    <p class="tooltip-example">Example: <code>artist:daft_punk, year:2013</code></p>
                                </div>
                            </div>
                        </div>
                        <button class="search-btn" @onclick="PerformSearch">Search</button>
                    </div>
                }
            </div>
        </div>
        }
        @if (_showPlaylistManager)
        {
            <AudioPlaylistManager OnClose="TogglePlaylistManager" />
        }
        else if (_showWatchManager)
        {
            <AudioWatchManager OnClose="ToggleWatchManager" />
        }
        else
        {
        <div class="list-cards glass-card">
            <div class="filters-bar">
                <div class="filter-group">
                    <button class="filter-btn @(_selectedSource == "all" && _selectedStatus == "all" && string.IsNullOrEmpty(_selectedPlaylistId) && _selectedSort == "title" && _isSortAscending ? "active" : "")" @onclick="ClearAllFiltersAsync">All</button>

                    <div class="sort-compound-pill">
                        <div class="custom-dropdown sort-dropdown compound-left">
                            <button class="dropdown-trigger @(_isSortDropdownOpen ? "active" : "")" @onclick="ToggleSortDropdown">
                                <span class="dropdown-selected-text">@GetSortDisplayText()</span>
                                <span class="dropdown-arrow">▼</span>
                            </button>
                            @if (_isSortDropdownOpen)
                            {
                                <div class="dropdown-popup glass-card">
                                    <div class="dropdown-item @(_selectedSort == "title" ? "active" : "")" @onclick='() => SelectSort("title")'>Title</div>
                                    <div class="dropdown-item @(_selectedSort == "artist" ? "active" : "")" @onclick='() => SelectSort("artist")'>Artist</div>
                                    <div class="dropdown-item @(_selectedSort == "year" ? "active" : "")" @onclick='() => SelectSort("year")'>Year</div>
                                    <div class="dropdown-item @(_selectedSort == "added" ? "active" : "")" @onclick='() => SelectSort("added")'>Added</div>
                                </div>
                            }
                        </div>

                        <button class="sort-toggle-btn compound-right" @onclick="ToggleSortDirection">
                            @(_isSortAscending ? "↑" : "↓")
                        </button>
                    </div>

                    <div class="split-pill mini">
                        <button class="split-btn @(_selectedSource == "manual" ? "active" : "")" @onclick='() => SetSourceFilter("manual")'>Manual</button>
                        <div class="divider"></div>
                        <button class="split-btn @(_selectedSource == "youtube" ? "active" : "")" @onclick='() => SetSourceFilter("youtube")'>YouTube</button>
                    </div>

                    <div class="custom-dropdown status-dropdown">
                        <button class="dropdown-trigger @(_isStatusDropdownOpen ? "active" : "")" @onclick="ToggleStatusDropdown">
                            <span class="dropdown-selected-text">@GetStatusDisplayText()</span>
                            <span class="dropdown-arrow">▼</span>
                        </button>
                        @if (_isStatusDropdownOpen)
                        {
                            <div class="dropdown-popup glass-card">
                                <div class="dropdown-item @(_selectedStatus == "all" ? "active" : "")" @onclick='() => SelectStatus("all")'>All</div>
                                <div class="dropdown-item @(_selectedStatus == "standard" ? "active" : "")" @onclick='() => SelectStatus("standard")'>Standard</div>
                                <div class="dropdown-item @(_selectedStatus == "partial" ? "active" : "")" @onclick='() => SelectStatus("partial")'>Partial</div>
                                <div class="dropdown-item @(_selectedStatus == "full" ? "active" : "")" @onclick='() => SelectStatus("full")'>Full</div>
                                <div class="dropdown-item @(_selectedStatus == "manual" ? "active" : "")" @onclick='() => SelectStatus("manual")'>Manual</div>
                                <div class="dropdown-item @(_selectedStatus == "disabled" ? "active" : "")" @onclick='() => SelectStatus("disabled")'>Locked</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="playlist-filter">
                    <div class="custom-dropdown">
                        <button class="dropdown-trigger @(_isPlaylistDropdownOpen ? "active" : "")" @onclick="TogglePlaylistDropdown">
                            <i class="icon-playlist"></i>
                            <span class="dropdown-selected-text">@(_selectedPlaylistName ?? "All Audio")</span>
                            <span class="dropdown-arrow">▼</span>
                        </button>
                        @if (_isPlaylistDropdownOpen)
                        {
                            <div class="dropdown-popup glass-card">
                                <div class="dropdown-item @(string.IsNullOrEmpty(_selectedPlaylistId) ? "active" : "")" 
                                        @onclick='() => SelectPlaylist(null, "All Audio")'>
                                    All Audio
                                </div>
                                <div class="dropdown-item @(_selectedPlaylistId == "any-playlist" ? "active" : "")" 
                                        @onclick='() => SelectPlaylist("any-playlist", "All Playlist")'>
                                    All Playlist
                                </div>
                                <div class="dropdown-item @(_selectedPlaylistId == "none-playlist" ? "active" : "")" 
                                        @onclick='() => SelectPlaylist("none-playlist", "No Playlist")'>
                                    No Playlist
                                </div>
                                <div class="dropdown-divider"></div>
                                @foreach (var p in _playlists)
                                {
                                    <div class="dropdown-item @(_selectedPlaylistId == p.GUID ? "active" : "")" 
                                            @onclick='() => SelectPlaylist(p.GUID, p.Name)'>
                                        @p.Name
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="loading-state">
                    <p>Loading audio library...</p>
                </div>
            }
            else if (!_audioRecords.Any())
            {
                <div class="empty-state">
                    <p>No audio records found in the library.</p>
                </div>
            }
            else
            {
                <div class="music-cards-grid @(_isSelectionMode ? "selection-mode" : "")">
                    @foreach (var record in FilteredRecords)
                    {
                        var isSelected = _selectedGuids.Contains(record.GUID);
                        var coverUrl = _coverArts.TryGetValue(record.GUID, out var url) ? url : "images/Assets/empty_cover.png";
                        var rawTitle = string.IsNullOrEmpty(record.AlternativeTitle) ? record.Title : record.AlternativeTitle;
                        var displayTitle = FilePathSanitizer.SterilizeTitle(rawTitle, _sterilizationTags);
                        var displayArtist = string.IsNullOrEmpty(record.Artist) ? "Unknown Artist" : record.Artist;
                        var displayYear = record.Year?.ToString() ?? "N/A";
                        
                        <div class="music-card @(isSelected ? "selected" : "")" @onclick="() => HandleAudioCardClick(record)">
                            @if (_isSelectionMode && isSelected)
                            {
                                <div class="selection-indicator">
                                    <i class="icon-check">✓</i>
                                </div>
                            }
                            <div class="music-card-top">
                                <div class="vinyl-wrapper">
                                    <div class="vinyl-inner">
                                        <div class="vinyl-rotating">
                                            <img class="vinyl-disc" src="images/Assets/vinyl_disc.png" alt="Vinyl Disc" />
                                            <img class="vinyl-center-art" src="@coverUrl" alt="Center Art" />
                                        </div>
                                    </div>
                                </div>
                                <div class="cover-art-container">
                                    <img class="cover-art" src="@coverUrl" alt="@displayTitle" />
                                </div>
                            </div>
                            <div class="music-card-bottom">
                                <div class="music-info-header">
                                    <div class="title-artist-stack">
                                        <h3 class="music-title" title="@displayTitle">@displayTitle</h3>
                                        <p class="music-artist" title="@displayArtist">@displayArtist</p>
                                    </div>
                                    <div class="card-actions-stack" @onclick:stopPropagation>
                                        <button class="enrich-btn @(IsRecordLocked(record) ? "enrich-disabled" : _enrichingGuids.Contains(record.GUID) ? "enriching" : "")" @onclick="() => EnrichSingleAsync(record)" 
                                                disabled="@(_enrichingGuids.Contains(record.GUID) || IsRecordLocked(record))" 
                                                title="@(IsRecordLocked(record) ? "Enrichment Locked" : "Enrich Metadata")">
                                            @if (_enrichingGuids.Contains(record.GUID))
                                            {
                                                <div class="btn-spinner"></div>
                                            }
                                            else if (IsRecordLocked(record))
                                            {
                                                <i class="icon-ban" title="Locked"></i>
                                            }
                                            else
                                            {
                                                <i class="icon-enrichment"></i>
                                            }
                                        </button>
                                        
                                        <div class="menu-wrapper" @onclick:stopPropagation>
                                            <button class="menu-trigger-btn" @onclick="() => ToggleMenu(record.GUID)" title="More options">
                                                ⋮
                                            </button>
                                            
                                            @if (_openMenuGuid == record.GUID)
                                            {
                                                <div class="context-menu glass-card">
                                                    <button class="menu-item" @onclick="() => RestoreOriginalAsync(record)" 
                                                            disabled="@(record.EnrichmentStatus == 0 || IsRecordLocked(record))"
                                                            title="Restore original metadata">
                                                        <i class="icon-restore"></i> De-Enrich
                                                    </button>
                                                    <button class="menu-item" @onclick="() => ToggleEnrichmentDisabledAsync(record)" 
                                                            title="@(IsRecordLocked(record) ? "Unlock enrichment" : "Lock enrichment")">
                                                        <i class="@(IsRecordLocked(record) ? "icon-enable" : "icon-disable")"></i> 
                                                        @(IsRecordLocked(record) ? "Unlock Enrich" : "Lock Enrich")
                                                    </button>
                                                    @if (!IsRecordLocked(record))
                                                    {
                                                        <div class="dropdown-divider"></div>
                                                        <button class="menu-item delete-item" @onclick="() => DeleteSingleAudioAsync(record)" title="Delete audio record and file">
                                                            <i class="icon-trash"></i> Delete
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="music-metadata-container">
                                    <div class="meta-stack">
                                        <p class="meta-text music-album" title="@record.Album">Album <span class="meta-dot">•</span> @(string.IsNullOrEmpty(record.Album) ? "N/A" : record.Album)</p>
                                        <p class="meta-text music-genre" title="@record.Genre">Genre <span class="meta-dot">•</span> @(string.IsNullOrEmpty(record.Genre) ? "N/A" : record.Genre)</p>
                                    </div>
                                    <div class="music-pills">
                                        <span class="pill year-pill">@displayYear</span>
                                        <span class="pill source-pill @(record.Source == "youtube" ? "youtube" : "manual")">
                                            @(record.Source == "youtube" ? "YouTube" : "Manual")
                                        </span>
                                        <span class="pill status-pill @GetStatusClass(record.EnrichmentStatus)"
                                              title="@GetStatusTitle(record.EnrichmentStatus)">
                                            @GetStatusText(record.EnrichmentStatus)
                                        </span>
                                    </div>
                                    @if (record.Bitrate.HasValue || record.SampleRate.HasValue || record.Duration.HasValue)
                                    {
                                        <div class="quality-row">
                                            <span class="pill rate-pill">
                                                @if (record.Bitrate.HasValue)
                                                {
                                                    @($"{record.Bitrate.Value} kbps")
                                                }
                                                @if (record.Bitrate.HasValue && record.SampleRate.HasValue)
                                                {
                                                    @(" • ")
                                                }
                                                @if (record.SampleRate.HasValue)
                                                {
                                                    @($"{(record.SampleRate.Value / 1000.0).ToString("0.#")} kHz")
                                                }
                                                @if (record.Bitrate.HasValue || record.SampleRate.HasValue)
                                                {
                                                    @(" • ")
                                                }
                                                @if (record.Duration.HasValue && record.Duration.Value > 0)
                                                {
                                                    @(TimeSpan.FromSeconds(record.Duration.Value).ToString(@"hh\:mm\:ss"))
                                                }
                                                else
                                                {
                                                    @("NO LENGTH DATA")
                                                }
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        }
    </div>

    @if (_recordToDelete != null)
    {
        <div class="modal-backdrop" @onclick="CancelDeleteSingle">
            <div class="modal-card glass-card" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Delete Track</h3>
                </div>
                <div class="modal-body">
                    <p class="modal-msg">Are you sure you want to delete <strong>@_recordToDelete.Title</strong>?</p>
                    <p class="warning-text">This will permanently delete the audio file, cover art, and metadata from your library. This action is irreversible.</p>
                </div>
                <div class="modal-footer">
                    <button class="action-btn select-audio" @onclick="CancelDeleteSingle">Cancel</button>
                    <button class="action-btn danger-btn" @onclick="ConfirmDeleteSingleAsync">Delete</button>
                </div>
            </div>
        </div>
    }

    @if (_editMetadataRecord != null)
    {
        <div class="modal-backdrop" @onclick="CloseMetadataEdit">
            <div class="modal-card metadata-modal glass-card" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Metadata Details</h3>
                </div>
                <div class="modal-body modal-columns">
                    <div class="column-left">
                        <div class="vinyl-preview-card">
                            <div class="vinyl-wrapper-modal">
                                <div class="vinyl-inner">
                                    <div class="vinyl-rotating">
                                        <img class="vinyl-disc" src="images/Assets/vinyl_disc.png" alt="Vinyl Disc" />
                                        <img class="vinyl-center-art" src="@(string.IsNullOrEmpty(_editCoverArtBase64) ? "images/Assets/empty_cover.png" : _editCoverArtBase64)" alt="Center Art" />
                                    </div>
                                </div>
                            </div>
                            <div class="cover-art-container-modal">
                                <img class="cover-art" src="@(string.IsNullOrEmpty(_editCoverArtBase64) ? "images/Assets/empty_cover.png" : _editCoverArtBase64)" alt="Preview Cover Art" />
                            </div>
                        </div>
                    </div>
                    <div class="column-right">
                        <!-- Editable Fields Grid -->
                        <div class="editable-grid">
                            <!-- Title -->
                            <div class="tech-item full-width editable-meta-item">
                                <span class="tech-label">Title</span>
                                <div class="editable-val-container">
                                    @if (!IsRecordLocked(_editMetadataRecord) && _editingTitleMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editTitle" @onblur="() => _editingTitleMode = false" @onkeydown="OnTitleKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => { if (!IsRecordLocked(_editMetadataRecord)) _editingTitleMode = true; }">@(string.IsNullOrEmpty(_editTitle) ? "N/A" : _editTitle)</span>
                                        @if (!IsRecordLocked(_editMetadataRecord))
                                        {
                                            <button class="pencil-btn" @onclick="() => _editingTitleMode = true">✎</button>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Artist -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Artist</span>
                                <div class="editable-val-container">
                                    @if (!IsRecordLocked(_editMetadataRecord) && _editingArtistMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editArtist" @onblur="() => _editingArtistMode = false" @onkeydown="OnArtistKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => { if (!IsRecordLocked(_editMetadataRecord)) _editingArtistMode = true; }">@(string.IsNullOrEmpty(_editArtist) ? "N/A" : _editArtist)</span>
                                        @if (!IsRecordLocked(_editMetadataRecord))
                                        {
                                            <button class="pencil-btn" @onclick="() => _editingArtistMode = true">✎</button>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Album -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Album</span>
                                <div class="editable-val-container">
                                    @if (!IsRecordLocked(_editMetadataRecord) && _editingAlbumMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editAlbum" @onblur="() => _editingAlbumMode = false" @onkeydown="OnAlbumKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => { if (!IsRecordLocked(_editMetadataRecord)) _editingAlbumMode = true; }">@(string.IsNullOrEmpty(_editAlbum) ? "N/A" : _editAlbum)</span>
                                        @if (!IsRecordLocked(_editMetadataRecord))
                                        {
                                            <button class="pencil-btn" @onclick="() => _editingAlbumMode = true">✎</button>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Genre -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Genre</span>
                                <div class="editable-val-container">
                                    @if (!IsRecordLocked(_editMetadataRecord) && _editingGenreMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editGenre" @onblur="() => _editingGenreMode = false" @onkeydown="OnGenreKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => { if (!IsRecordLocked(_editMetadataRecord)) _editingGenreMode = true; }">@(string.IsNullOrEmpty(_editGenre) ? "N/A" : _editGenre)</span>
                                        @if (!IsRecordLocked(_editMetadataRecord))
                                        {
                                            <button class="pencil-btn" @onclick="() => _editingGenreMode = true">✎</button>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Year -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Year</span>
                                <div class="editable-val-container">
                                    @if (!IsRecordLocked(_editMetadataRecord) && _editingYearMode)
                                    {
                                        <input type="number" class="form-input inline-edit" @bind="_editYear" min="1000" max="3000" @onblur="() => _editingYearMode = false" @onkeydown="OnYearKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => { if (!IsRecordLocked(_editMetadataRecord)) _editingYearMode = true; }">@(_editYear.HasValue ? _editYear.Value.ToString() : "N/A")</span>
                                        @if (!IsRecordLocked(_editMetadataRecord))
                                        {
                                            <button class="pencil-btn" @onclick="() => _editingYearMode = true">✎</button>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Cover Art Upload -->
                            <div class="tech-item full-width editable-meta-item">
                                <span class="tech-label">Cover Art</span>
                                @if (IsRecordLocked(_editMetadataRecord))
                                {
                                    <div class="file-upload-wrapper inline-upload" style="opacity: 0.5; cursor: not-allowed;">
                                        <span class="file-upload-btn" style="pointer-events: none;">Choose Image</span>
                                        <span class="file-name-label">@(_uploadedCoverArtFileName != "" ? _uploadedCoverArtFileName : (!string.IsNullOrEmpty(_editCoverArtPath) ? System.IO.Path.GetFileName(_editCoverArtPath) : "No file chosen"))</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="file-upload-wrapper inline-upload" @onclick="PickCoverArtNativeAsync">
                                        <span class="file-upload-btn">Choose Image</span>
                                        <span class="file-name-label">@(_uploadedCoverArtFileName != "" ? _uploadedCoverArtFileName : (!string.IsNullOrEmpty(_editCoverArtPath) ? System.IO.Path.GetFileName(_editCoverArtPath) : "No file chosen"))</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Technical Read-only Fields Grid -->
                        <div class="technical-metadata-section">
                            <div class="tech-grid-4">
                                <div class="tech-item">
                                    <span class="tech-label">Source</span>
                                    <span class="tech-val">@_editMetadataRecord.Source</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">YouTube ID</span>
                                    <span class="tech-val">@(string.IsNullOrEmpty(_editMetadataRecord.YoutubeID) ? "N/A" : _editMetadataRecord.YoutubeID)</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">Format</span>
                                    <span class="tech-val">@_editMetadataRecord.Extension.ToUpper().TrimStart('.')</span>
                                </div>
                                <div class="tech-item">
