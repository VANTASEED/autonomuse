    private async Task PickCoverArtNativeAsync()
    {
        try
        {
            var options = new PickOptions
            {
                PickerTitle = "Select Cover Art Image",
                FileTypes = FilePickerFileType.Images
            };

            var result = await FilePicker.Default.PickAsync(options);
            if (result != null)
            {
                _uploadedCoverArtFileName = result.FileName;
                
                using var stream = await result.OpenReadAsync();
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                _uploadedCoverArtBytes = ms.ToArray();
                _hasNewCoverArtUploaded = true;

                var ext = Path.GetExtension(result.FileName).ToLowerInvariant();
                var mimeType = ext switch
                {
                    ".png" => "image/png",
                    ".webp" => "image/webp",
                    _ => "image/jpeg"
                };
                _editCoverArtBase64 = $"data:{mimeType};base64,{Convert.ToBase64String(_uploadedCoverArtBytes)}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to pick native file: {ex.Message}");
        }
    }

    private string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue) return "N/A";
        string[] suffixes = { "B", "KB", "MB", "GB" };
        double len = bytes.Value;
        int order = 0;
        while (len >= 1024 && order < suffixes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {suffixes[order]}";
    }

    private string FormatDuration(double? seconds)
    {
        if (!seconds.HasValue || seconds.Value <= 0) return "N/A";
        return TimeSpan.FromSeconds(seconds.Value).ToString(@"hh\:mm\:ss");
    }

    private bool IsRecordLocked(AudioRecord record)
    {
        if (record == null) return false;
        return record.EnrichmentStatus == 3 || record.EnrichmentStatus >= 10;
    }

    private string GetStatusClass(int status)
    {
        if (status >= 10 || status == 3) return "disabled";
        return status switch
        {
            1 => "full",
            2 => "partial",
            4 => "manual",
            _ => "standard"
        };
    }

    private string GetStatusTitle(int status)
    {
        if (status >= 10 || status == 3) return "Enrichment locked";
        return status switch
        {
            1 => "Fully enriched",
            2 => "Partially enriched",
            4 => "Manually edited",
            _ => "No enrichment"
        };
    }

    private string GetStatusText(int status)
    {
        if (status >= 10 || status == 3) return "Locked";
        return status switch
        {
            1 => "Full",
            2 => "Partial",
            4 => "Manual",
            _ => "Standard"
        };
    }

    private async Task SaveMetadataChangesAsync()
    {
        if (_editMetadataRecord == null || _isSavingMetadata) return;
        if (IsRecordLocked(_editMetadataRecord)) return;

        _isSavingMetadata = true;
        StateHasChanged();

        try
        {
            var record = _editMetadataRecord;

            // Create backup before first modification (preserves original data before manual edits)
            if (record.EnrichmentStatus != 4)
            {
                await EnsureAudioBackupCreatedAsync(record);
            }

            record.AlternativeTitle = _editTitle;
            record.Artist = _editArtist;
            record.Album = _editAlbum;
            record.Genre = _editGenre;
            record.Year = _editYear;
            record.EnrichmentStatus = 4; // Set to Manual

            if (_hasNewCoverArtUploaded && _uploadedCoverArtBytes != null)
            {
                using var ms = new MemoryStream(_uploadedCoverArtBytes);
                var savedPath = await AudioService.SaveCoverArtAsync(record.GUID, ms);
                record.CoverArtPath = savedPath;
            }

            await AudioService.UpdateAudioRecordAsync(record);
            await AudioService.UpdatePhysicalTagsAsync(record);

            _editMetadataRecord = null;
            await LoadAudioRecordsAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to save metadata: {ex.Message}");
        }
        finally
        {
            _isSavingMetadata = false;
            StateHasChanged();
        }
    }

    private async Task LockSelectedAsync()
    {
        if (_selectedGuids.Count == 0) return;
        var toLock = _audioRecords.Where(r => _selectedGuids.Contains(r.GUID) && !IsRecordLocked(r)).ToList();
        foreach (var record in toLock)
        {
            record.EnrichmentStatus = 10 + record.EnrichmentStatus;
            await AudioService.UpdateAudioRecordAsync(record);
        }
        _selectedGuids.Clear();
        _isSelectionMode = false;
        await LoadAudioRecordsAsync();
    }

    private async Task UnlockSelectedAsync()
    {
        if (_selectedGuids.Count == 0) return;
        var toUnlock = _audioRecords.Where(r => _selectedGuids.Contains(r.GUID) && IsRecordLocked(r)).ToList();
        foreach (var record in toUnlock)
        {
            record.EnrichmentStatus = record.EnrichmentStatus >= 10 ? record.EnrichmentStatus - 10 : 0;
            await AudioService.UpdateAudioRecordAsync(record);
        }
        _selectedGuids.Clear();
        _isSelectionMode = false;
        await LoadAudioRecordsAsync();
    }

    private async Task EnrichSelectedAsync()
    {
        if (_selectedGuids.Count == 0 || _isEnrichingAll) return;
        
        // Exclude tracks that are locked
        var toEnrich = _audioRecords.Where(r => _selectedGuids.Contains(r.GUID) && !IsRecordLocked(r)).ToList();
        if (toEnrich.Count == 0) return;

        _isEnrichingAll = true;
        _globalProgress = 0;
        int current = 0;
        int total = toEnrich.Count;
        
        _isSelectionMode = false; // Turn off selection mode while processing
        
        try 
        {
            foreach (var record in toEnrich)
            {
                current++;
                _globalProgressMessage = $"Processing: {record.Title}";
                _globalProgress = (double)current / total;
                StateHasChanged();
                
                await EnrichmentService.EnrichAudioAsync(record);
            }
            await LoadAudioRecordsAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Selected enrichment failed: {ex.Message}");
        }
        finally
        {
            _isEnrichingAll = false;
            _selectedGuids.Clear();
            StateHasChanged();
        }
    }
}
