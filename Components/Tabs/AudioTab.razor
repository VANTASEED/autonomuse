        if (_selectedGuids.Count == 0 || _isEnrichingAll) return;

        _showDeleteConfirm = false;
        _isLoading = true;
        StateHasChanged();

        try
        {
            var guidsToDelete = _selectedGuids.ToList();
            // Safety: exclude any locked records
            var audioLookup = _audioRecords?.Where(r => guidsToDelete.Contains(r.GUID)).ToDictionary(r => r.GUID);
            var nonLocked = guidsToDelete.Where(g => audioLookup == null || !audioLookup.ContainsKey(g) || !IsRecordLocked(audioLookup[g])).ToList();
            foreach (var guid in nonLocked)
            {
                await AudioService.DeleteAudioAsync(guid);
            }
            _selectedGuids.Clear();
            _isSelectionMode = false;
            await LoadAudioRecordsAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Batch deletion failed: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
