                    var mimeType = ext switch
                    {
                        ".png" => "image/png",
                        ".webp" => "image/webp",
                        ".gif" => "image/gif",
                        _ => "image/jpeg"
                    };
                    
                    try
                    {
                        var bytes = await System.IO.File.ReadAllBytesAsync(record.CoverArtPath);
                        _coverArts[record.GUID] = $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}";
                    }
                    catch
                    {
                        _coverArts[record.GUID] = "images/Assets/empty_cover.png";
                    }
                }
                else
                {
                    _coverArts[record.GUID] = "images/Assets/empty_cover.png";
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading audio: {ex.Message}");
