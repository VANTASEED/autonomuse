@using Autonomuse.Domain.Entities
@using Autonomuse.Shared.Contracts
@using Autonomuse.Shared.Utilities
@inject IVideoService VideoService
@inject ISettingsService SettingsService
@inject VideoWatchService WatchService
@inject IJSRuntime JSRuntime

<div class="tab-content">
    <div class="header">
        @if (_showPlaylistManager)
        {
            <h1>Video Gallery / Video Playlist Manager</h1>
            <p>Add or remove videos from your playlists</p>
        }
        else if (_showWatchManager)
        {
            <h1>Video Gallery / Watcher</h1>
            <p>Monitor YouTube playlists for new videos</p>
        }
        else
        {
            <h1>Video Gallery</h1>
            <p>Watch and organize your movie and video clips</p>
        }
    </div>

    <div class="video-content">
        @if (!_showPlaylistManager && !_showWatchManager)
        {
        <!-- Control actions / Bulk operations bar -->
        <div class="control-cards glass-card">
            <div class="control-actions">
                @if (!_isSelectionMode)
                {
                    <button class="action-btn" @onclick="ToggleSelectionMode">
                        Select
                    </button>
                    <button class="action-btn" @onclick="TogglePlaylistManager">
                        Manage
                    </button>
                    <div class="split-pill mini">
                        <button class="split-btn" @onclick="ToggleWatchManager">Watcher</button>
                        <div class="divider"></div>
                        <button class="split-btn" @onclick="SyncWatchedPlaylistsAsync" title="Sync all watched playlists">
                            <span class="@(WatchService.IsSyncing ? "spin-icon" : "")">↻</span>
                        </button>
                    </div>
                }
                else
                {
                    <div class="split-pill mini">
                        <button class="split-btn" @onclick="ToggleSelectionMode">Cancel</button>
                        <div class="divider"></div>
                        <button class="split-btn" @onclick="SelectAll">Select All</button>
                    </div>
                    @if (_showDeleteConfirm)
                    {
                        <div class="confirm-group">
                            <span class="confirm-text">Delete @_selectedGuids.Count items?</span>
                            <button class="action-btn danger-btn" @onclick="ConfirmDeleteSelectedAsync">Confirm</button>
                            <button class="action-btn select-audio" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                        </div>
                    }
                    else
                    {
                        <button class="action-btn" @onclick="LockSelectedAsync" disabled="@(_selectedGuids.Count == 0)">
                            <i class="icon-disable"></i> Lock (@_selectedGuids.Count)
                        </button>
                        <button class="action-btn" @onclick="UnlockSelectedAsync" disabled="@(_selectedGuids.Count == 0)">
                            <i class="icon-enable"></i> Unlock (@_selectedGuids.Count)
                        </button>
                        <button class="action-btn danger-btn" @onclick="() => _showDeleteConfirm = true" disabled="@(_selectedGuids.Count == 0)">
                            Delete Selected (@_selectedGuids.Count)
                        </button>
                    }
                }

                <div class="search-container">
                    <div class="search-input-wrapper">
                        <i class="icon-search-mini"></i>
                        <input type="text" 
                               @bind="_searchQuery" 
                               @bind:event="oninput" 
                               @onkeyup="HandleSearchKeyUp"
                               placeholder="artist:director_name, genre:sci-fi..." 
                               class="search-input" />
                        @if (!string.IsNullOrEmpty(_searchQuery))
                        {
                            <button class="clear-search" @onclick="ClearSearch">×</button>
                        }
                        <div class="search-tooltip">
                            <div class="tooltip-header">Search Tags</div>
                            <div class="tooltip-body">
                                <p>Filter your library using tags separated by commas, <br/>and use underscores for multi-word tags:</p>
                                <ul>
                                    <li><strong>source</strong> filter by source (e.g. <code>youtube</code>, <code>manual</code>)</li>
                                    <li><strong>artist</strong> filter by creator/artist (e.g. <code>daft_punk</code>)</li>
                                    <li><strong>genre</strong> filter by genre (e.g. <code>entertainment</code>)</li>
                                    <li><strong>year</strong> filter by year (e.g. <code>2025</code>)</li>
                                    <li><strong>title</strong> filter by video title</li>
                                </ul>
                                <p class="tooltip-example">Example: <code>artist:daft_punk, year:2025</code></p>
                            </div>
                        </div>
                    </div>
                    <button class="search-btn" @onclick="PerformSearch">Search</button>
                </div>
            </div>
        </div>
        }
        @if (_showPlaylistManager)
        {
            <VideoPlaylistManager OnClose="TogglePlaylistManager" />
        }
        else if (_showWatchManager)
        {
            <VideoWatchManager OnClose="ToggleWatchManager" />
        }
        else
        {
        <div class="list-cards glass-card">
            <!-- Filter Bar -->
            <div class="filters-bar">
                <div class="filter-group">
                    <button class="filter-btn @(_selectedSource == "all" && string.IsNullOrEmpty(_selectedPlaylistId) && _selectedSort == "title" && _isSortAscending ? "active" : "")" @onclick="ClearAllFiltersAsync">All</button>

                    <div class="sort-compound-pill">
                        <div class="custom-dropdown sort-dropdown compound-left">
                            <button class="dropdown-trigger @(_isSortDropdownOpen ? "active" : "")" @onclick="ToggleSortDropdown">
                                <span class="dropdown-selected-text">@GetSortDisplayText()</span>
                                <span class="dropdown-arrow">▼</span>
                            </button>
                            @if (_isSortDropdownOpen)
                            {
                                <div class="dropdown-popup glass-card">
                                    <div class="dropdown-item @(_selectedSort == "title" ? "active" : "")" @onclick='() => SelectSort("title")'>Title</div>
                                    <div class="dropdown-item @(_selectedSort == "artist" ? "active" : "")" @onclick='() => SelectSort("artist")'>Artist</div>
                                    <div class="dropdown-item @(_selectedSort == "year" ? "active" : "")" @onclick='() => SelectSort("year")'>Year</div>
                                    <div class="dropdown-item @(_selectedSort == "added" ? "active" : "")" @onclick='() => SelectSort("added")'>Added</div>
                                </div>
                            }
                        </div>

                        <button class="sort-toggle-btn compound-right" @onclick="ToggleSortDirection">
                            @(_isSortAscending ? "↑" : "↓")
                        </button>
                    </div>

                    <div class="split-pill mini">
                        <button class="split-btn @(_selectedSource == "manual" ? "active" : "")" @onclick='() => SetSourceFilter("manual")'>Manual</button>
                        <div class="divider"></div>
                        <button class="split-btn @(_selectedSource == "youtube" ? "active" : "")" @onclick='() => SetSourceFilter("youtube")'>YouTube</button>
                    </div>

                    <div class="status-filter">
                        <div class="custom-dropdown">
                            <button class="dropdown-trigger @(_isStatusDropdownOpen ? "active" : "")" @onclick="ToggleStatusDropdown">
                                <span class="dropdown-selected-text">@GetSelectedStatusDisplay()</span>
                                <span class="dropdown-arrow">▼</span>
                            </button>
                            @if (_isStatusDropdownOpen)
                            {
                                <div class="dropdown-popup glass-card">
                                    <div class="dropdown-item @(_selectedMetadataStatus == "all" ? "active" : "")" @onclick='() => SelectMetadataStatus("all")'>All Status</div>
                                    <div class="dropdown-item @(_selectedMetadataStatus == "standard" ? "active" : "")" @onclick='() => SelectMetadataStatus("standard")'>Standard</div>
                                    <div class="dropdown-item @(_selectedMetadataStatus == "manual" ? "active" : "")" @onclick='() => SelectMetadataStatus("manual")'>Manual</div>
                                    <div class="dropdown-item @(_selectedMetadataStatus == "disabled" ? "active" : "")" @onclick='() => SelectMetadataStatus("disabled")'>Locked</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="playlist-filter">
                        <div class="custom-dropdown">
                            <button class="dropdown-trigger @(_isPlaylistDropdownOpen ? "active" : "")" @onclick="TogglePlaylistDropdown">
                                <i class="icon-playlist"></i>
                                <span class="dropdown-selected-text">@(_selectedPlaylistName ?? "All Videos")</span>
                                <span class="dropdown-arrow">▼</span>
                            </button>
                            @if (_isPlaylistDropdownOpen)
                            {
                                <div class="dropdown-popup glass-card">
                                    <div class="dropdown-item @(string.IsNullOrEmpty(_selectedPlaylistId) ? "active" : "")" 
                                            @onclick='() => SelectPlaylist(null, "All Videos")'>
                                        All Videos
                                    </div>
                                    <div class="dropdown-item @(_selectedPlaylistId == "any-playlist" ? "active" : "")" 
                                            @onclick='() => SelectPlaylist("any-playlist", "All Playlists")'>
                                        All Playlists
                                    </div>
                                    <div class="dropdown-item @(_selectedPlaylistId == "none-playlist" ? "active" : "")" 
                                            @onclick='() => SelectPlaylist("none-playlist", "No Playlists")'>
                                        No Playlists
                                    </div>
                                    <div class="dropdown-divider"></div>
                                    @foreach (var p in _playlists)
                                    {
                                        <div class="dropdown-item @(_selectedPlaylistId == p.GUID ? "active" : "")" 
                                                @onclick='() => SelectPlaylist(p.GUID, p.Name)'>
                                            @p.Name
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

            <!-- Video Grid -->
            @if (_isLoading)
            {
                <div class="loading-state">
                    <p>Loading video gallery...</p>
                </div>
            }
            else if (!FilteredRecords.Any())
            {
                <div class="empty-state">
                    <p>No video records found matching the filters.</p>
                </div>
            }
            else
            {
                <div class="video-cards-grid @(_isSelectionMode ? "selection-mode" : "")">
                    @foreach (var record in FilteredRecords)
                    {
                        var thumbUrl = !string.IsNullOrEmpty(record.ThumbnailPath) && System.IO.File.Exists(record.ThumbnailPath) 
                            ? _thumbnails.TryGetValue(record.GUID, out var url) ? url : "images/Assets/empty_thumbnail.png"
                            : "images/Assets/empty_thumbnail.png";
                            
                        var rawTitle = string.IsNullOrEmpty(record.AlternativeTitle) ? record.Title : record.AlternativeTitle;
                        var displayTitle = FilePathSanitizer.SterilizeTitle(rawTitle, _sterilizationTags);
                        var displayArtist = string.IsNullOrEmpty(record.Artist) ? "Unknown Creator" : record.Artist;
                        var displayYear = record.Year?.ToString() ?? "Unknown Year";
                        var isChecked = _selectedGuids.Contains(record.GUID);
                        
                        <div class="video-card @(isChecked ? "selected" : "")" @onclick="() => HandleCardClick(record)">
                            @if (_isSelectionMode && isChecked)
                            {
                                <div class="selection-indicator">
                                    <i class="icon-check">✓</i>
                                </div>
                            }
                            <div class="video-card-top">
                                <div class="vhs-tape-wrapper">
                                    <div class="vhs-tape-inner">
                                        <img class="vhs-tape-img" src="images/Assets/vhs_tape.png" alt="VHS Tape" />
                                        <img class="vhs-tape-label" src="@thumbUrl" alt="Tape Label" />
                                    </div>
                                </div>
                                <div class="vhs-sleeve-container">
                                    <img class="vhs-sleeve-thumb" src="@thumbUrl" alt="@displayTitle" />
                                </div>
                            </div>
                            <div class="video-card-bottom">
                                <div class="title-action-row">
                                    <h3 class="video-title" title="@displayTitle">@displayTitle</h3>
                                    @if (!_isSelectionMode)
                                    {
                                        <div class="menu-wrapper" @onclick:stopPropagation>
                                            <button class="menu-trigger-btn" @onclick="() => ToggleMenu(record.GUID)" title="More options">
                                                ⋮
                                            </button>
                                            @if (_openMenuGuid == record.GUID)
                                            {
                                                <div class="context-menu glass-card">
                                                    @if (record.MetadataStatus == 1)
                                                    {
                                                        <button class="menu-item" @onclick="() => ResetMetadataAsync(record)" 
                                                                disabled="@IsRecordLocked(record)"
                                                                title="Restore original metadata from backup">
                                                            <i class="icon-restore"></i> Recover Original
                                                        </button>
                                                    }
                                                    <button class="menu-item" @onclick="() => ToggleMetadataDisabledAsync(record)" 
                                                            title="@(IsRecordLocked(record) ? "Unlock metadata" : "Lock metadata")">
                                                        <i class="@(IsRecordLocked(record) ? "icon-enable" : "icon-disable")"></i> 
                                                        @(IsRecordLocked(record) ? "Unlock" : "Lock")
                                                    </button>
                                                    @if (!IsRecordLocked(record))
                                                    {
                                                        <div class="dropdown-divider"></div>
                                                        <button class="menu-item delete-item" @onclick="() => DeleteSingleVideoAsync(record)" title="Delete video record and file">
                                                            <i class="icon-trash"></i> Delete
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                <p class="video-artist" title="@displayArtist">@displayArtist</p>
                                <div class="video-metadata-container">
                                    <div class="meta-stack">
                                        <p class="meta-text" title="@record.Genre">Genre <span class="meta-dot">•</span> @(string.IsNullOrEmpty(record.Genre) ? "N/A" : record.Genre)</p>
                                    </div>
                                    <div class="video-pills">
                                        <span class="pill year-pill">@displayYear</span>
                                        <span class="pill source-pill @(record.Source == "youtube" ? "youtube" : "manual")">
                                            @(record.Source == "youtube" ? "YouTube" : "Manual")
                                        </span>
                                        <span class="pill status-pill @GetMetadataStatusClass(record.MetadataStatus)"
                                              title="@GetMetadataStatusTitle(record.MetadataStatus)">
                                            @GetMetadataStatusText(record.MetadataStatus)
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(record.Resolution) || record.Duration.HasValue)
                                    {
                                        <div class="quality-row">
                                            <span class="pill res-pill">
                                                @if (!string.IsNullOrEmpty(record.Resolution))
                                                {
                                                    @record.Resolution
                                                    @(" • ")
                                                }
                                                @if (record.Duration.HasValue && record.Duration.Value > 0)
                                                {
                                                    @(TimeSpan.FromSeconds(record.Duration.Value).ToString(@"hh\:mm\:ss"))
                                                }
                                                else
                                                {
                                                    @("NO LENGTH DATA")
                                                }
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        }
    </div>

    @if (_deleteConfirmRecord != null)
    {
        <div class="modal-backdrop" @onclick="CancelSingleDelete">
            <div class="modal-card glass-card" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Delete Video</h3>
                </div>
                <div class="modal-body">
                    <p class="modal-msg">Are you sure you want to delete <strong>@_deleteConfirmRecord.Title</strong>?</p>
                    <p class="warning-text">This will permanently delete the video file, cover art, and metadata from your library. This action is irreversible.</p>
                </div>
                <div class="modal-footer">
                    <button class="action-btn select-audio" @onclick="CancelSingleDelete">Cancel</button>
                    <button class="action-btn danger-btn" @onclick="ConfirmSingleDeleteAsync">Delete</button>
                </div>
            </div>
        </div>
    }

    <!-- Metadata Details & Edit Modal -->
    @if (_editMetadataRecord != null)
    {
        <div class="modal-backdrop" @onclick="CloseMetadataEdit">
            <div class="modal-card metadata-modal glass-card" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Metadata Details</h3>
                </div>
                <div class="modal-body modal-columns">
                    <div class="column-left">
                        <div class="vhs-preview-card">
                            <div class="vhs-tape-wrapper-modal">
                                <div class="vhs-tape-inner-modal">
                                    <img class="vhs-tape-img" src="images/Assets/vhs_tape.png" alt="VHS Tape" />
                                    <img class="vhs-tape-label" src="@(string.IsNullOrEmpty(_editCoverArtBase64) ? "images/Assets/empty_thumbnail.png" : _editCoverArtBase64)" alt="Tape Label" />
                                </div>
                            </div>
                            <div class="vhs-sleeve-container-modal">
                                <img class="vhs-sleeve-thumb" src="@(string.IsNullOrEmpty(_editCoverArtBase64) ? "images/Assets/empty_thumbnail.png" : _editCoverArtBase64)" alt="Tape Sleeve" />
                            </div>
                        </div>
                    </div>
                    <div class="column-right">
                        <!-- Editable Fields Grid -->
                        <div class="editable-grid">
                            <!-- Title -->
                            <div class="tech-item full-width editable-meta-item">
                                <span class="tech-label">Title</span>
                                <div class="editable-val-container">
                                    @if (_editingTitleMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editTitle" @onblur="() => _editingTitleMode = false" @onkeydown="OnTitleKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => _editingTitleMode = true">@(string.IsNullOrEmpty(_editTitle) ? "N/A" : _editTitle)</span>
                                        <button class="pencil-btn" @onclick="() => _editingTitleMode = true">✎</button>
                                    }
                                </div>
                            </div>

                            <!-- Artist (Director) -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Artist / Creator</span>
                                <div class="editable-val-container">
                                    @if (_editingArtistMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editArtist" @onblur="() => _editingArtistMode = false" @onkeydown="OnArtistKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => _editingArtistMode = true">@(string.IsNullOrEmpty(_editArtist) ? "N/A" : _editArtist)</span>
                                        <button class="pencil-btn" @onclick="() => _editingArtistMode = true">✎</button>
                                    }
                                </div>
                            </div>

                            <!-- Genre -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Genre</span>
                                <div class="editable-val-container">
                                    @if (_editingGenreMode)
                                    {
                                        <input type="text" class="form-input inline-edit" @bind="_editGenre" @onblur="() => _editingGenreMode = false" @onkeydown="OnGenreKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => _editingGenreMode = true">@(string.IsNullOrEmpty(_editGenre) ? "N/A" : _editGenre)</span>
                                        <button class="pencil-btn" @onclick="() => _editingGenreMode = true">✎</button>
                                    }
                                </div>
                            </div>

                            <!-- Year -->
                            <div class="tech-item editable-meta-item">
                                <span class="tech-label">Year</span>
                                <div class="editable-val-container">
                                    @if (_editingYearMode)
                                    {
                                        <input type="number" class="form-input inline-edit" @bind="_editYear" min="1000" max="3000" @onblur="() => _editingYearMode = false" @onkeydown="OnYearKeyDown" autofocus />
                                    }
                                    else
                                    {
                                        <span class="tech-val" @onclick="() => _editingYearMode = true">@(_editYear.HasValue ? _editYear.Value.ToString() : "N/A")</span>
                                        <button class="pencil-btn" @onclick="() => _editingYearMode = true">✎</button>
                                    }
                                </div>
                            </div>

                            <!-- Cover Art / Thumbnail Upload -->
                            <div class="tech-item full-width editable-meta-item">
                                <span class="tech-label">Thumbnail Image</span>
                                <div class="file-upload-wrapper inline-upload" @onclick="PickCoverArtNativeAsync">
                                    <span class="file-upload-btn">Choose Image</span>
                                    <span class="file-name-label">@(_uploadedCoverArtFileName != "" ? _uploadedCoverArtFileName : (!string.IsNullOrEmpty(_editCoverArtPath) ? System.IO.Path.GetFileName(_editCoverArtPath) : "No file chosen"))</span>
                                </div>
                            </div>
                        </div>

                        <!-- Technical Read-only Fields Grid -->
                        <div class="technical-metadata-section">
                            <div class="tech-grid-4">
                                <div class="tech-item">
                                    <span class="tech-label">Source</span>
                                    <span class="tech-val">@_editMetadataRecord.Source</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">YouTube ID</span>
                                    <span class="tech-val">@(string.IsNullOrEmpty(_editMetadataRecord.YoutubeID) ? "N/A" : _editMetadataRecord.YoutubeID)</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">Format</span>
                                    <span class="tech-val">@_editMetadataRecord.Extension.ToUpper().TrimStart('.')</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">File Size</span>
                                    <span class="tech-val">@FormatFileSize(_editMetadataRecord.FileSize)</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">Duration</span>
                                    <span class="tech-val">@FormatDuration(_editMetadataRecord.Duration)</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">Resolution</span>
                                    <span class="tech-val">@(string.IsNullOrEmpty(_editMetadataRecord.Resolution) ? "N/A" : _editMetadataRecord.Resolution)</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">Audio Bitrate</span>
                                    <span class="tech-val">@(_editMetadataRecord.Bitrate.HasValue ? $"{_editMetadataRecord.Bitrate} kbps" : "N/A")</span>
                                </div>
                                <div class="tech-item">
                                    <span class="tech-label">Audio Channels</span>
                                    <span class="tech-val">@(_editMetadataRecord.Channels.HasValue ? (_editMetadataRecord.Channels == 2 ? "Stereo" : "Mono") : "N/A")</span>
                                </div>
                                <div class="tech-item span-4">
                                    <span class="tech-label">File Path</span>
                                    <span class="tech-val" title="@_editMetadataRecord.FilePath">@_editMetadataRecord.FilePath</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="action-btn select-audio" @onclick="CloseMetadataEdit" disabled="@_isSavingMetadata">Cancel</button>
                    <button class="action-btn" @onclick="SaveMetadataChangesAsync" disabled="@_isSavingMetadata">
                        @if (_isSavingMetadata)
                        {
                            <span class="btn-spinner mini"></span> @(" Saving...")
                        }
                        else
                        {
                            @("Save Changes")
                        }
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<VideoRecord> _videoRecords = new();
    private List<VideoRecord> _filteredRecords = new();
    private Dictionary<string, string> _thumbnails = new();
    private List<string> _sterilizationTags = new();
    private bool _isLoading = true;

    // Filters state
    private string _searchQuery = "";
    private string _selectedSource = "all";
    private string? _selectedPlaylistId = null;
    private string? _selectedPlaylistName = null;
    private string _selectedSort = "title";
    private string _selectedMetadataStatus = "all";
    private bool _isSortAscending = true;

    // Dropdown toggles
    private bool _isSortDropdownOpen = false;
    private bool _isPlaylistDropdownOpen = false;
    private bool _isStatusDropdownOpen = false;

    // Playlists list
    private List<MediaPlaylist> _playlists = new();
    private List<VideoRecord> _playlistItems = new();
    private HashSet<string> _guidsInAnyPlaylist = new();

    // Selection mode state
    private bool _isSelectionMode = false;
    private HashSet<string> _selectedGuids = new();
    private bool _showDeleteConfirm = false;
    private bool _showPlaylistManager = false;
    private bool _showWatchManager = false;

    // Context menu state
    private string? _openMenuGuid = null;

    // Single delete confirm state
    private VideoRecord? _deleteConfirmRecord = null;

    // Metadata Details popup state
    private VideoRecord? _editMetadataRecord = null;
    private string _editTitle = "";
    private string _editArtist = "";
    private string _editGenre = "";
    private int? _editYear = null;
    private string? _editCoverArtPath = null;
    private string? _editCoverArtBase64 = null;
    
    // Inline edit triggers
    private bool _editingTitleMode = false;
    private bool _editingArtistMode = false;
    private bool _editingGenreMode = false;
    private bool _editingYearMode = false;

    // Native file picking inside modal
    private bool _hasNewCoverArtUploaded = false;
    private byte[]? _uploadedCoverArtBytes = null;
    private string _uploadedCoverArtFileName = "";
    private bool _isSavingMetadata = false;

    private List<VideoRecord> FilteredRecords => _filteredRecords;

    protected override async Task OnInitializedAsync()
    {
        await LoadVideoRecordsAsync();
        _playlists = await VideoService.GetPlaylistsAsync();
        _guidsInAnyPlaylist = await VideoService.GetVideoGuidsInAnyPlaylistAsync();
    }

