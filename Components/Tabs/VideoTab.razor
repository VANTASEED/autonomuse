    private async Task ResetMetadataAsync(VideoRecord record)
    {
        _openMenuGuid = null;
        try
        {
            var backup = await VideoService.GetVideoBackupAsync(record.GUID);
            if (backup == null)
            {
                System.Diagnostics.Debug.WriteLine("No backup found for this video.");
                return;
            }

            var libraryPath = await SettingsService.GetSettingAsync("LibraryPath");

            // Restore thumbnail
            if (!string.IsNullOrEmpty(libraryPath))
            {
                var standardThumbPath = Path.Combine(libraryPath, "Art", "Video", $"{record.GUID}.jpg");
                var backupFolder = Path.Combine(libraryPath, "Art", "VideoBackup");
                var backupThumbPath = Path.Combine(backupFolder, $"{record.GUID}.jpg");

                if (string.IsNullOrEmpty(backup.ThumbnailPath))
                {
                    if (System.IO.File.Exists(standardThumbPath)) System.IO.File.Delete(standardThumbPath);
                    record.ThumbnailPath = null;
                }
                else
                {
                    if (System.IO.File.Exists(backupThumbPath))
                    {
                        var destDir = Path.GetDirectoryName(standardThumbPath);
                        if (!string.IsNullOrEmpty(destDir) && !Directory.Exists(destDir))
                            Directory.CreateDirectory(destDir);

                        System.IO.File.Copy(backupThumbPath, standardThumbPath, true);
                        System.IO.File.Delete(backupThumbPath);
                        record.ThumbnailPath = standardThumbPath;
                    }
                }
            }

            record.AlternativeTitle = backup.AlternativeTitle;
            record.Title = backup.AlternativeTitle ?? record.FileName;
            record.Artist = backup.Artist;
            record.Genre = backup.Genre;
            record.Year = backup.Year;
            record.MetadataStatus = 0;

            await VideoService.UpdateVideoRecordAsync(record);
            await VideoService.UpdatePhysicalTagsAsync(record);
            await VideoService.DeleteVideoBackupAsync(record.GUID);
            await LoadVideoRecordsAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to reset metadata: {ex.Message}");
        }
    }

    private async Task EnsureVideoBackupCreatedAsync(VideoRecord record)
    {
        try
        {
            var existing = await VideoService.GetVideoBackupAsync(record.GUID);
            if (existing != null) return;

            var backup = new VideoBackup
            {
                GUID = record.GUID,
                AlternativeTitle = record.AlternativeTitle,
                Artist = record.Artist,
                Genre = record.Genre,
                Year = record.Year,
                ThumbnailPath = record.ThumbnailPath,
                CreatedAt = DateTime.UtcNow
            };
            await VideoService.CreateVideoBackupAsync(backup);

            // Backup thumbnail file if it exists
            if (!string.IsNullOrEmpty(record.ThumbnailPath) && System.IO.File.Exists(record.ThumbnailPath))
            {
                try
                {
                    var libraryPath = await SettingsService.GetSettingAsync("LibraryPath");
                    if (!string.IsNullOrEmpty(libraryPath))
                    {
                        var backupFolder = Path.Combine(libraryPath, "Art", "VideoBackup");
                        if (!Directory.Exists(backupFolder)) Directory.CreateDirectory(backupFolder);

                        var backupPath = Path.Combine(backupFolder, $"{record.GUID}.jpg");
                        if (!System.IO.File.Exists(backupPath))
                        {
                            System.IO.File.Copy(record.ThumbnailPath, backupPath);
                        }
                    }
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"Failed to backup thumbnail: {ex.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"EnsureVideoBackupCreatedAsync failed: {ex.Message}");
        }
    }

    private string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue) return "N/A";
        string[] suffixes = { "B", "KB", "MB", "GB" };
        double len = bytes.Value;
        int order = 0;
        while (len >= 1024 && order < suffixes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {suffixes[order]}";
    }

    private string FormatDuration(double? seconds)
    {
        if (!seconds.HasValue || seconds.Value <= 0) return "N/A";
        return TimeSpan.FromSeconds(seconds.Value).ToString(@"hh\:mm\:ss");
    }
