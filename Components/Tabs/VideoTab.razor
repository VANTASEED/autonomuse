    private async Task ApplyFiltersAsync()
    {
        var results = _videoRecords.AsEnumerable();

        // 1. Source Filter
        if (_selectedSource == "manual") results = results.Where(r => r.Source != "youtube");
        else if (_selectedSource == "youtube") results = results.Where(r => r.Source == "youtube");

        // 2. Playlist Filter
        if (!string.IsNullOrEmpty(_selectedPlaylistId))
        {
            if (_selectedPlaylistId == "any-playlist")
            {
                results = results.Where(r => _guidsInAnyPlaylist.Contains(r.GUID));
            }
            else if (_selectedPlaylistId == "none-playlist")
            {
                results = results.Where(r => !_guidsInAnyPlaylist.Contains(r.GUID));
            }
            else
            {
                var guidsInPlaylist = _playlistItems.Select(p => p.GUID).ToHashSet();
                results = results.Where(r => guidsInPlaylist.Contains(r.GUID));
            }
        }

        // 3. Search Query
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var segments = _searchQuery.Split(',', StringSplitOptions.RemoveEmptyEntries);
            foreach (var segment in segments)
            {
                var parts = segment.Split(':', 2);
                if (parts.Length < 2) continue;

                var tag = parts[0].Trim().ToLower();
                var value = parts[1].Trim().ToLower().Replace("_", " ");

                results = tag switch
                {
                    "source" => results.Where(r => r.Source.ToLower().Contains(value)),
                    "artist" => results.Where(r => (r.Artist ?? "").ToLower().Contains(value)),
                    "genre" => results.Where(r => (r.Genre ?? "").ToLower().Contains(value)),
                    "year" => results.Where(r => r.Year?.ToString() == value),
                    "title" => results.Where(r => r.Title.ToLower().Contains(value) || (r.AlternativeTitle ?? "").ToLower().Contains(value)),
                    _ => results
                };
            }
        }

        // 4. Metadata Status Filter
        if (_selectedMetadataStatus == "standard") results = results.Where(r => r.MetadataStatus == 0);
        else if (_selectedMetadataStatus == "manual") results = results.Where(r => r.MetadataStatus == 1);
        else if (_selectedMetadataStatus == "disabled") results = results.Where(r => r.MetadataStatus >= 10);

        // 5. Sorting
        results = _selectedSort switch
        {
            "title" => _isSortAscending 
                ? results.OrderBy(r => GetSortGroup(GetSortTitle(r))).ThenBy(r => GetSortTitle(r))
                : results.OrderByDescending(r => GetSortGroup(GetSortTitle(r))).ThenByDescending(r => GetSortTitle(r)),
            "artist" => _isSortAscending 
                ? results.OrderBy(r => string.IsNullOrEmpty(r.Artist) ? "zzz" : r.Artist)
                : results.OrderByDescending(r => string.IsNullOrEmpty(r.Artist) ? "zzz" : r.Artist),
            "year" => _isSortAscending 
                ? results.OrderBy(r => r.Year ?? 9999)
                : results.OrderByDescending(r => r.Year ?? 0),
            "added" => _isSortAscending 
                ? results.OrderBy(r => r.CreatedAt)
                : results.OrderByDescending(r => r.CreatedAt),
            _ => results
        };

        _filteredRecords = results.ToList();
        StateHasChanged();
    }

    private string GetSortTitle(VideoRecord r) => string.IsNullOrEmpty(r.AlternativeTitle) ? r.Title : r.AlternativeTitle;

    private int GetSortGroup(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return 1;
        var firstChar = text.TrimStart().FirstOrDefault();
        return char.IsLetter(firstChar) ? 0 : 1;
    }

