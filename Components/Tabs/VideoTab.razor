    private async Task LoadVideoRecordsAsync()
    {
        _isLoading = true;
        try
        {
            // Load sterilization tags
            var sterilizationStr = await SettingsService.GetSettingAsync("StringSterilization");
            if (!string.IsNullOrEmpty(sterilizationStr))
            {
                _sterilizationTags = sterilizationStr.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
            }

            _videoRecords = await VideoService.GetAllVideosAsync();
            
            _thumbnails.Clear();
            foreach(var record in _videoRecords)
            {
                if (!string.IsNullOrEmpty(record.ThumbnailPath) && System.IO.File.Exists(record.ThumbnailPath))
                {
                    try
                    {
                        var bytes = await System.IO.File.ReadAllBytesAsync(record.ThumbnailPath);
                        _thumbnails[record.GUID] = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
                    }
                    catch
                    {
                        _thumbnails[record.GUID] = "images/Assets/empty_thumbnail.png";
                    }
                }
            }
            await ApplyFiltersAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading video: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

