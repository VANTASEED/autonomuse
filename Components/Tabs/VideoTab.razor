    private async Task PickCoverArtNativeAsync()
    {
        try
        {
            var options = new PickOptions
            {
                PickerTitle = "Please select a custom video thumbnail image",
                FileTypes = FilePickerFileType.Images
            };

            var result = await FilePicker.Default.PickAsync(options);
            if (result != null)
            {
                _uploadedCoverArtFileName = result.FileName;
                
                using var stream = await result.OpenReadAsync();
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                _uploadedCoverArtBytes = ms.ToArray();
                _hasNewCoverArtUploaded = true;

                var ext = Path.GetExtension(result.FileName).ToLowerInvariant();
                var mimeType = ext switch
                {
                    ".png" => "image/png",
                    ".webp" => "image/webp",
                    _ => "image/jpeg"
                };
                _editCoverArtBase64 = $"data:{mimeType};base64,{Convert.ToBase64String(_uploadedCoverArtBytes)}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to pick native file: {ex.Message}");
        }
    }

    private async Task SaveMetadataChangesAsync()
    {
        if (_editMetadataRecord == null || _isSavingMetadata) return;

        _isSavingMetadata = true;
        StateHasChanged();

        try
        {
            var record = _editMetadataRecord;

            // Create backup before first modification
            if (record.MetadataStatus == 0)
            {
                await EnsureVideoBackupCreatedAsync(record);
            }

            record.AlternativeTitle = _editTitle;
            record.Artist = _editArtist;
            record.Genre = _editGenre;
            record.Year = _editYear;
            record.MetadataStatus = 1;

            if (_hasNewCoverArtUploaded && _uploadedCoverArtBytes != null)
            {
                using var ms = new MemoryStream(_uploadedCoverArtBytes);
                var savedPath = await VideoService.SaveThumbnailAsync(record.GUID, ms);
                record.ThumbnailPath = savedPath;
            }

            await VideoService.UpdateVideoRecordAsync(record);
            await VideoService.UpdatePhysicalTagsAsync(record);

            _editMetadataRecord = null;
            await LoadVideoRecordsAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to save video metadata: {ex.Message}");
        }
        finally
        {
            _isSavingMetadata = false;
            StateHasChanged();
        }
    }

